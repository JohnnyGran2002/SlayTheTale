    "m_FunctionBody": "Color = 1;\n#if defined(UNIVERSAL_LIGHTING_INCLUDED)\n\r\n\t#ifdef SHADERGRAPH_PREVIEW\r\n\t\tColor = 1;\r\n\t#else\n\t\tLight light = GetMainLight();\n\t\tColor = light.color;\n\t#endif\n#endif"
}

